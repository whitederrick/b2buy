{
  "name": "b2buy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",

    "db:start":        "supabase start",
    "db:stop":         "supabase stop",
    "db:status":       "supabase status",
    "db:reset":        "supabase db reset",
    "db:diff":         "supabase db diff",
    "db:push":         "supabase db push",
    "db:pull":         "supabase db pull",
    "db:link":         "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "db:types":        "supabase gen types typescript --linked > lib/database.types.ts",

    "db:seed":         "supabase db reset --seed-file supabase/seed.sql",
    "db:studio":       "open http://127.0.0.1:54323",

    "secret:gen":      "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "next": "15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "8.5.10",
    "supabase": "^2.105.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
