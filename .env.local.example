# =============================================================================
# B2BUY нҷҳкІҪліҖмҲҳ (.env.local)
# - .env.localмқҖ gitм—җ м»Өл°Ӣ кёҲм§Җ (.gitignoreм—җ нҸ¬н•ЁлҗЁ)
# - Supabase н”„лЎңм қнҠё мғқм„ұ нӣ„ Settings > API м—җм„ң URL/Key нҷ•мқё
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Supabase (н•„мҲҳ)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...    # anon (public) key
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_ACCESS_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...        # service_role (м ҲлҢҖ нҒҙлқјмқҙм–ёнҠё л…ём¶ң кёҲм§Җ)

# -----------------------------------------------------------------------------
# 2) Vercel Cron Secret (м •мӮ° мҠӨмјҖмӨ„лҹ¬ мқёмҰқ)
#    - openssl rand -hex 32 лЎң мғқм„ұ
#    - vercel.jsonмқҳ crons + app/api/deals/settle/route.tsм—җм„ң мӮ¬мҡ©
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# 3) (м„ нғқ) н•ҳлӮҳмқҖн–ү м—җмҠӨнҒ¬лЎң м—”л“ңнҸ¬мқёнҠё
#    - мӢӨ м—°лҸҷ мӢң: app/api/deals/settle/route.tsмқҳ triggerHanaEscrowOrder()
# -----------------------------------------------------------------------------
HANA_ESCROW_ENDPOINT=
HANA_ESCROW_API_KEY=

# -----------------------------------------------------------------------------
# 4) (м„ нғқ) мӮ¬мқҙнҠё URL (мқҙл©”мқј мқёмҰқ/лҰ¬лӢӨмқҙл үнҠё base)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
